	ignore = dirty
[submodule "site-lisp/transient"]
	path = site-lisp/transient
	url = https://github.com/magit/transient.git
	ignore = dirty
[submodule "site-lisp/magit"]
	path = site-lisp/magit
	url = https://github.com/magit/magit.git
	ignore = dirty
[submodule "site-lisp/cond-let"]
	path = site-lisp/cond-let
	url = https://github.com/tarsius/cond-let.git
	ignore = dirty
[submodule "site-lisp/llama"]
	path = site-lisp/llama
	url = https://github.com/tarsius/llama.git
	ignore = dirty
